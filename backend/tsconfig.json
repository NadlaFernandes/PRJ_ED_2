{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",      // O 'bundler' exige módulos modernos
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true, // Útil para bundlers
    "noEmit": true,                     // Geralmente bundlers lidam com a transpilação
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "rootDir": "./src",
    "outDir": "./dist",
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}